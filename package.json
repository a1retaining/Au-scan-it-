{
  "name": "asx-trade-finder",
  "version": "0.3.0",
  "private": true,
  "description": "ASX Trade Finder monorepo root. Frontend lives in ./frontend and backend lives in ./src.",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend ci && npm --prefix frontend run build",
    "start": "npm --prefix frontend run preview -- --host 0.0.0.0 --port ${PORT:-4173}",
    "frontend:install": "npm --prefix frontend ci",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:dev": "npm --prefix frontend run dev",
    "test": "python -m pytest",
    "api": "uvicorn asx_trade_finder.api:app --host 0.0.0.0 --port ${PORT:-8000}"
  },
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  }
}
